# worklab-patroni-failover-slots — environment
# Copy to .env and adjust. All values have sane defaults.

# --- PostgreSQL / Patroni ---
PG_MAJOR=18
PATRONI_VERSION=4.1.3
POSTGRES_PASSWORD=postgres
REPLICATION_PASSWORD=replicator
PATRONI_SCOPE=cdc-demo

# Host port mappings (host -> container)
PATRONI1_PG_PORT=15432
PATRONI2_PG_PORT=15433
PATRONI1_API_PORT=18008
PATRONI2_API_PORT=18009

# HAProxy: leader-aware routing so the CDC consumer always reaches the primary
HAPROXY_PRIMARY_PORT=5000     # always routes to the current leader (read-write)
HAPROXY_REPLICA_PORT=5001     # routes to replicas (read-only)
HAPROXY_STATS_PORT=7000

# --- Demo database / CDC objects ---
DEMO_DB=cdcdemo
CDC_SLOT=cdc_slot
CDC_PUBLICATION=cdc_pub
CDC_TABLE=public.orders

# --- Kafka (KRaft, single node, no ZooKeeper) ---
KAFKA_IMAGE=apache/kafka:3.8.1
KAFKA_PORT=9092

# --- Debezium Kafka Connect ---
# slot.failover requires Debezium >= 3.0.5 connecting to a PostgreSQL 17+ primary.
DEBEZIUM_VERSION=3.1
CONNECT_PORT=8083

# --- Supporting images ---
ETCD_IMAGE=quay.io/coreos/etcd:v3.5.9
HAPROXY_IMAGE=haproxy:lts-alpine
