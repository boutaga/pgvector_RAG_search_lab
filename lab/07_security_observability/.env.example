# =============================================================================
# Lab 07 — Security Observability Demo (Swiss PGDay 2026)
# Copy to .env and fill OPENAI_API_KEY. The real .env is gitignored.
# =============================================================================

# --- OpenAI ---------------------------------------------------------------
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- PostgreSQL: lab07_pg18 container -------------------------------------
PGHOST=localhost
PGPORT=5436
PGDATABASE=secobs
PGUSER=dba_admin
PGPASSWORD=dbi2026!

# App login role (non-superuser, RLS applies). Used by ask.py / measure.
APP_USER=app_user
APP_PASSWORD=dbi2026!
# Masked role (sees anon-faked client names). Used by embed.py --mode masked.
MASKED_USER=bank_masked
MASKED_PASSWORD=dbi2026!
